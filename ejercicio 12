public class BuscarMatriz {

    public static boolean buscar(int[][] m, int target) {

        int i = 0;
        int j = m[0].length - 1;

        while (i < m.length && j >= 0) {

            if (m[i][j] == target) {
                return true;
            }

            if (target > m[i][j]) {
                j--; 
            } else {
                i++; 
            }
        }

        return false;
    }
}
