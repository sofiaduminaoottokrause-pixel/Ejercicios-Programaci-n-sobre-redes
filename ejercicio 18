public class Incremento {

    public static int[] sumarUno(int[] arr) {

        for (int i = arr.length - 1; i >= 0; i--) {

            if (arr[i] < 9) {
                arr[i] = arr[i] + 1;
                return arr;
            }
            arr[i] = 0;
        }
        int[] nuevo = new int[arr.length + 1];
        nuevo[0] = 1;

        return nuevo;
    }
}
