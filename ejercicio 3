public class MultiplicadorArreglo {

    public static int[] multiplicar(int[] digitos, int k) {
       
        int decena_correr = 0;
        
              int[] resultadoTemp = new int[digitos.length + 1];
        int indiceRes = resultadoTemp.length - 1;

        for (int i = digitos.length - 1; i >= 0; i--) {
            int producto = (digitos[i] * k) + decena_correr;
            
            resultadoTemp[indiceRes] = producto % 10; 
            decena_correr = producto / 10;                
            indiceRes--;
        }

                if (decena_correr > 0) {
            resultadoTemp[indiceRes] = decena_correr;
            return resultadoTemp; 
        } 
else {
                        int[] resultadoFinal = new int[digitos.length];
            for (int i = 0; i < digitos.length; i++) {
                resultadoFinal[i] = resultadoTemp[i + 1];
            }
            return resultadoFinal;
        }
    }
